---
import Nav from "./../../data/nav.json";
import { FaWhatsapp } from "react-icons/fa";
const currentPath = Astro.url.pathname;
---

<nav class="border-b border-gray-300 px-4 py-4 sticky top-0 bg-white z-999">
    <div class="flex justify-between items-center sm:w-[95%] sm:mx-auto">
        <a href="/" class="text-xl font-semibold sm:font-bold sm:text-2xl">
            <!-- <span class="text-red-700">SERPONG</span>
            <span class="text-blue-600">TELCO</span> -->
            <img src="/images/logo.png" alt="logo" class="w-[180px] h-[55px] sm:w-60 sm:h-16.25" />
        </a>

        <!-- MOBILE DROPWOWN MENU -->
        <div class="dropdown dropdown-end sm:hidden">
            <div tabindex="0" role="button" class="btn btn-ghost btn-circle">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
                </svg>
            </div>
            <ul tabindex="-1" class="menu menu-sm dropdown-content rounded-box z-1 mt-3 p-2 shadow bg-white w-28">
                {
                    Nav.map((val) => (
                        <li>
                            <a
                                href={val.href}
                                class={
                                    val.type === "btn"
                                        ? "bg-green-500 rounded-md text-white mt-4 font-semibold"
                                        : "" + ` text-sm ${currentPath === val.href ? "text-blue-600" : "text-black"}`
                                }
                            >
                                <>
                                    {val.type === "btn" && <FaWhatsapp size="16px" />}
                                    {val.label}
                                </>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>

        <!-- DESKTOP  MENU -->
        <ul class="hidden sm:flex gap-4 items-center">
            {
                Nav.map((val) => (
                    <li>
                        <a
                            href={val.href}
                            class={
                                val.type === "btn"
                                    ? `bg-green-500 rounded-md text-white px-4 py-2 flex items-center gap-2 text-lg ms-4 `
                                    : "" +
                                      ` text-lg font-semibold hover:text-blue-600 ${currentPath === val.href ? "text-blue-600" : "text-black"}`
                            }
                        >
                            <>
                                {val.type === "btn" && <FaWhatsapp size="22px" />}
                                {val.label}
                            </>
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</nav>
